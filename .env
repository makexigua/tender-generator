# 钉钉 AI 助理配置
DINGTALK_API_URL=<钉钉agent接口地址>
DINGTALK_BEARER_TOKEN=
DINGTALK_ASSISTANT_ID=
DINGTALK_UNION_ID=
DINGTALK_INPUT_TEXT=请根据以下招标文件内容，撰写一份完整的投标文件，返回调用MCP服务生成的文件地址。
DINGTALK_STREAM=false
DINGTALK_THREAD_ID=

# 标书状态更新接口
